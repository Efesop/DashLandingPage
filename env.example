# Stripe Configuration
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys

# Server-side secret key (starts with sk_)
STRIPE_SECRET_KEY=sk_test_...

# Client-side publishable key (starts with pk_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret for verifying webhook signatures
# Get this from your Stripe Dashboard: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Base URL for your application
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: Stripe API version (defaults to latest stable)
STRIPE_API_VERSION=2024-06-20

# ============================================
# Voltage Configuration (Bitcoin/Lightning Payments)
# ============================================
# Sign up at: https://voltage.cloud
# Docs: https://docs.voltageapi.com

# Voltage API Key (from Dashboard → API Keys)
VOLTAGE_API_KEY=your-api-key

# Voltage Organization ID (from Dashboard)
VOLTAGE_ORG_ID=your-organization-id

# Voltage Environment ID (from Dashboard)
VOLTAGE_ENV_ID=your-environment-id

# Voltage Wallet ID (from Dashboard → Wallets)
VOLTAGE_WALLET_ID=your-wallet-id

# Optional: Webhook secret for signature verification
VOLTAGE_WEBHOOK_SECRET=your-webhook-shared-secret
